<?
require_once("/usr/local/emhttp/plugins/appdata.cleanup.ng/include/caCredits.php");
require_once("/usr/local/emhttp/plugins/appdata.cleanup.ng/include/helpers.php");

$plugin = "appdata.cleanup.ng";
$dockerRunning = is_dir("/var/lib/docker/tmp") ? "true" : "false";
$acngDockerCfg = @my_parse_ini_file("/boot/config/docker.cfg");
$acngAppdataLoc = isset($acngDockerCfg['DOCKER_APP_CONFIG_PATH']) ? rtrim($acngDockerCfg['DOCKER_APP_CONFIG_PATH'],"/") : "/mnt/user/appdata";
if ( ! isset($var) || ! is_array($var) ) $var = @parse_ini_file("/var/local/emhttp/var.ini");
$csrfToken = isset($var['csrf_token']) ? $var['csrf_token'] : "";

function tr($string,$ret=false) {
	$string = str_replace('"',"&#34;",str_replace("'","&#39;",_($string)));
	if ( $ret )
		return $string;
	else
		echo $string;
}
?>
<style>
.acng-intro { margin:6px 0 10px; opacity:.95; font-size:1.05em; line-height:1.4; }
.acng-bullets { margin:0 0 14px; padding-left:22px; opacity:.9; font-size:1em; line-height:1.5; }
.acng-bullets li { margin:3px 0; }
.acng-detected { margin:0 0 14px; font-size:.95em; opacity:.9; }
.acng-detected code { padding:1px 6px; border-radius:3px; background:rgba(128,128,128,.15); }
.acng-detected-note { opacity:.65; font-size:.9em; }
